rules_version = '2';

service cloud.firestore {

  function isOwner(userId) {
    return request.auth != null && request.auth.uid == userId;
  }

  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, update, create: if isOwner(userId);
      allow delete: if false;

      // Stacks + their nested transactions sub-collection
      match /stacks/{stackId} {
        allow read, write: if isOwner(userId);
        match /transactions/{txId} {
          allow read, write: if isOwner(userId);
        }
      }

      // Ideas
      match /ideas/{ideaId} {
        allow read, write: if isOwner(userId);
      }

      // Invoices
      match /invoices/{invoiceId} {
        allow read, write: if isOwner(userId);
      }

      // imported_bank_tx_ids — read-only for client, written by Cloud Functions
      match /imported_bank_tx_ids/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // bank_connections, bank_auth_state, rate_limits have NO rules here
      // → denied by default (Firestore denies when no rule matches)
    }

    // Deny everything outside /users
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
